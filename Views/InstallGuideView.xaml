<UserControl x:Class="pkz.Views.InstallGuideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <TextBlock Text="{Binding ManagerName, StringFormat='{}{0}이(가) 설치되어 있지 않습니다.'}"
               FontSize="18"
               HorizontalAlignment="Center"
               Margin="0,0,0,0"/>

        <TextBlock Text="아래 버튼을 눌러 설치할 수 있습니다."
               HorizontalAlignment="Center"
               Margin="0,0,0,12"
               Visibility="{Binding ManagerName, Converter={StaticResource managerToVisibleCvt}, ConverterParameter=Invert}"/>

        <Button Content="설치하기"
            HorizontalAlignment="Center"
            Margin="0,0,0,12"
            Visibility="{Binding ManagerName, Converter={StaticResource managerToVisibleCvt}, ConverterParameter=Invert}"/>

        <TextBlock Text="Windows 업데이트를 통해 winget을 설치할 수 있습니다."
               HorizontalAlignment="Center"
               Visibility="{Binding ManagerName, Converter={StaticResource managerToVisibleCvt}}"/>

    </StackPanel>
</UserControl>